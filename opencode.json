{
    "$schema": "https://opencode.ai/config.json",
    "lsp": {
        "typescript": {
            "command": ["pnpm", "exec", "typescript-language-server", "--stdio"],
            "extensions": [".ts", ".tsx", ".js", ".jsx", ".mjs", ".cjs", ".mts", ".cts"]
        },
        "vue": {
            "command": ["pnpm", "exec", "vue-language-server", "--stdio"],
            "extensions": [".vue"]
        }
    }
}
