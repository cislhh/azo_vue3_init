{
  "name": "azo-vue3-init",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit --project tsconfig.app.json && vite build",
    "test": "vitest",
    "format": "prettier --write .",
    "type-check": "tsc --noEmit --project tsconfig.app.json",
    "lint": "eslint .",
    "lint:css": "stylelint '**/*.{css,scss,vue}'",
    "check": "npm run type-check && npm run lint && npm run lint:css",
    "check:ts": "npm run type-check",
    "check:eslint": "npm run lint",
    "check:css": "npm run lint:css"
  },
  "dependencies": {
    "@logicflow/core": "^2.1.11",
    "@logicflow/extension": "^2.1.15",
    "@onlyoffice/document-editor-vue": "^1.6.1",
    "@tailwindcss/vite": "^4.2.2",
    "@vue-flow/background": "^1.3.2",
    "@vue-flow/core": "^1.48.2",
    "autoprefixer": "^10.4.27",
    "axios": "1.13.6",
    "echarts": "^6.0.0",
    "es-toolkit": "^1.45.1",
    "pinia": "^3.0.4",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "vue": "^3.5.30",
    "vue-router": "5"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.0.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/language-server": "^3.2.6",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.0",
    "commitlint": "^20.5.0",
    "eslint-plugin-format": "^2.0.1",
    "naive-ui": "^2.44.1",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "stylelint": "^17.6.0",
    "stylelint-config-recommended-scss": "^17.0.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "~5.9.3",
    "typescript-language-server": "^5.1.3",
    "vite": "^8.0.1",
    "vite-plugin-checker": "^0.12.0",
    "vitest": "^4.1.2",
    "vue-tsc": "^3.2.5"
  }
}
